{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "CursorPosition": {
      "type": "object",
      "properties": {
        "line": { "type": "integer", "minimum": 0 },
        "column": { "type": "integer", "minimum": 0 }
      },
      "required": ["line", "column"],
      "additionalProperties": false
    },
    "ActiveFile": {
      "type": "object",
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "language_id": { "type": "string", "minLength": 1 },
        "content": { "type": "string" },
        "cursor_position": { "$ref": "#/definitions/CursorPosition" }
      },
      "required": ["path", "language_id", "content", "cursor_position"],
      "additionalProperties": false
    },
    "Selection": {
      "type": ["object", "null"],
      "properties": {
        "text": { "type": "string" },
        "start_line": { "type": "integer", "minimum": 0 },
        "end_line": { "type": "integer", "minimum": 0 },
        "start_column": { "type": "integer", "minimum": 0 },
        "end_column": { "type": "integer", "minimum": 0 }
      },
      "required": ["text", "start_line", "end_line", "start_column", "end_column"],
      "additionalProperties": false
    },
    "OpenTab": {
      "type": "object",
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "language_id": { "type": "string", "minLength": 1 },
        "content": { "type": "string" }
      },
      "required": ["path", "language_id", "content"],
      "additionalProperties": false
    },
    "DiagnosticRange": {
      "type": "object",
      "properties": {
        "start": { "$ref": "#/definitions/CursorPosition" },
        "end": { "$ref": "#/definitions/CursorPosition" }
      },
      "required": ["start", "end"],
      "additionalProperties": false
    },
    "Diagnostic": {
      "type": "object",
      "properties": {
        "message": { "type": "string" },
        "severity": { "type": "string", "enum": ["error", "warning", "information", "hint"] },
        "range": { "$ref": "#/definitions/DiagnosticRange" },
        "source": { "type": "string" }
      },
      "required": ["message", "severity", "range", "source"],
      "additionalProperties": false
    },
    "ContextBundle": {
      "type": "object",
      "properties": {
        "active_file": { "$ref": "#/definitions/ActiveFile" },
        "selection": { "$ref": "#/definitions/Selection" },
        "open_tabs": {
          "type": "array",
          "items": { "$ref": "#/definitions/OpenTab" },
          "maxItems": 10
        },
        "workspace_structure": { "type": "object" },
        "git_diff": { "type": "string" },
        "diagnostics": {
          "type": "array",
          "items": { "$ref": "#/definitions/Diagnostic" },
          "maxItems": 50
        },
        "terminal_snapshot": { "type": ["string", "null"] },
        "pre_compression_token_estimate": { "type": "integer", "minimum": 0 },
        "heavy_context_flag": { "type": "boolean" }
      },
      "required": [
        "active_file", "selection", "open_tabs", "workspace_structure",
        "git_diff", "diagnostics", "terminal_snapshot",
        "pre_compression_token_estimate", "heavy_context_flag"
      ],
      "additionalProperties": false
    },
    "ToolResult": {
      "type": "object",
      "properties": {
        "tool_call_id": { "type": "string", "minLength": 1 },
        "tool_name": { "type": "string", "minLength": 1 },
        "output": { "type": "string" },
        "is_error": { "type": "boolean" }
      },
      "required": ["tool_call_id", "tool_name", "output", "is_error"],
      "additionalProperties": false
    },
    "NexusPayload": {
      "type": "object",
      "properties": {
        "session_id": { "type": "string", "format": "uuid" },
        "request_id": { "type": "string", "format": "uuid" },
        "timestamp": { "type": "string", "format": "date-time" },
        "model_alias": { "type": "string", "minLength": 1 },
        "stream": { "type": "boolean" },
        "user_message": { "type": "string" },
        "provider_key_alias": { "type": "string", "minLength": 1 },
        "context_bundle": { "$ref": "#/definitions/ContextBundle" },
        "history_ref": { "type": "string", "format": "uuid" },
        "tool_results": {
          "type": ["array", "null"],
          "items": { "$ref": "#/definitions/ToolResult" }
        }
      },
      "required": [
        "session_id", "request_id", "timestamp", "model_alias", "stream",
        "user_message", "provider_key_alias", "context_bundle",
        "history_ref", "tool_results"
      ],
      "additionalProperties": false
    },
    "ToolCall": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "tool_name": { "type": "string", "minLength": 1 },
        "arguments": { "type": "object" }
      },
      "required": ["id", "tool_name", "arguments"],
      "additionalProperties": false
    },
    "UsageStats": {
      "type": "object",
      "properties": {
        "prompt_tokens": { "type": "integer", "minimum": 0 },
        "completion_tokens": { "type": "integer", "minimum": 0 },
        "total_tokens": { "type": "integer", "minimum": 0 }
      },
      "required": ["prompt_tokens", "completion_tokens", "total_tokens"],
      "additionalProperties": false
    },
    "ResponseError": {
      "type": ["object", "null"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string" },
        "layer": {
          "type": "string",
          "enum": ["cache", "memory", "compression", "router", "provider", "tool_loop"]
        },
        "is_retryable": { "type": "boolean" }
      },
      "required": ["code", "message", "layer", "is_retryable"],
      "additionalProperties": false
    },
    "NexusResponse": {
      "type": "object",
      "properties": {
        "request_id": { "type": "string" },
        "session_id": { "type": "string" },
        "response_text": { "type": ["string", "null"] },
        "tool_calls": {
          "type": ["array", "null"],
          "items": { "$ref": "#/definitions/ToolCall" }
        },
        "is_final": { "type": "boolean" },
        "cache_hit": { "type": "boolean" },
        "cache_tier": { "type": ["string", "null"], "enum": ["L1", "L2", null] },
        "memory_nodes_retrieved": { "type": "integer", "minimum": 0 },
        "pre_compression_tokens": { "type": "integer", "minimum": 0 },
        "post_compression_tokens": { "type": "integer", "minimum": 0 },
        "compression_ratio": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "usage": { "$ref": "#/definitions/UsageStats" },
        "model_used": { "type": "string" },
        "cost_estimate_usd": { "type": "number", "minimum": 0.0 },
        "error": { "$ref": "#/definitions/ResponseError" }
      },
      "required": [
        "request_id", "session_id", "response_text", "tool_calls",
        "is_final", "cache_hit", "cache_tier", "memory_nodes_retrieved",
        "pre_compression_tokens", "post_compression_tokens",
        "compression_ratio", "usage", "model_used", "cost_estimate_usd", "error"
      ],
      "additionalProperties": false
    }
  }
}
